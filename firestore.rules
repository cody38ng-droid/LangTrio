rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---

    function isValidUser(data) {
      return data.keys().hasAll(['displayName', 'totalXp']) &&
             data.keys().size() <= 20 &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.totalXp is number && data.totalXp >= 0 &&
             (!('email' in data) || (data.email is string && data.email.size() <= 150)) &&
             (!('avatar' in data) || (data.avatar is string && data.avatar.size() <= 300)) &&
             (!('pointsByLanguage' in data) || (data.pointsByLanguage is map)) &&
             (!('badges' in data) || (data.badges is list)) &&
             (!('globalStats' in data) || (data.globalStats is map)) &&
             (!('lastActive' in data) || (data.lastActive is timestamp)) &&
             (!('createdAt' in data) || (data.createdAt is timestamp));
    }

    function isValidUserProgress(data) {
      return data.keys().hasAll(['language', 'overallLevel', 'sectionLevels']) &&
             data.keys().size() <= 15 &&
             data.language is string &&
             data.overallLevel is string &&
             data.sectionLevels is map &&
             (!('sectionStreaks' in data) || (data.sectionStreaks is map)) &&
             (!('completedModules' in data) || (data.completedModules is list)) &&
             (!('moduleHistory' in data) || (data.moduleHistory is map)) &&
             (!('srsItems' in data) || (data.srsItems is list)) &&
             (!('earnedBadges' in data) || (data.earnedBadges is list));
    }

    function isValidScore(data) {
      return data.keys().hasAll(['userId', 'language', 'score', 'timestamp']) &&
             data.keys().size() <= 12 &&
             data.userId == request.auth.uid &&
             data.language is string && data.language.size() <= 20 &&
             data.score is number && data.score >= 0 && data.score <= 100 &&
             data.timestamp == request.time &&
             (!('userName' in data) || (data.userName is string && data.userName.size() <= 100)) &&
             (!('userAvatar' in data) || (data.userAvatar is string && data.userAvatar.size() <= 300)) &&
             (!('xpGained' in data) || (data.xpGained is number));
    }

    // --- Routes ---

    match /users/{userId} {
      allow get: if true; // Public profiles for leaderboard
      allow list: if true; // To find top users
      allow create: if isOwner(userId) && (
        // Allow full profile creation
        isValidUser(incoming()) || 
        // Allow partial creation from globalStats sync if needed (though we prefer full)
        (incoming().keys().hasOnly(['globalStats', 'lastActive', 'displayName', 'totalXp']))
      );
      allow update: if isOwner(userId) && (
        // Action: Generic update
        (isValidUser(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['totalXp', 'pointsByLanguage', 'badges', 'displayName', 'avatar', 'lastActive', 'globalStats', 'email']))
      );

      match /progress/{language} {
        allow get, list: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidUserProgress(incoming());
        allow delete: if false;
      }
    }

    match /scores/{scoreId} {
      allow get: if true;
      allow list: if true; // Public leaderboard
      allow create: if isSignedIn() && isValidId(scoreId) && isValidScore(incoming());
      allow update, delete: if false; // Immutable scores
    }
  }
}
